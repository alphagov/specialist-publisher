<% format_name = f.object.class.finder_schema.filter["format"].to_sym %>
<% schema = f.object.class.finder_schema %>
<%= render "govuk_publishing_components/components/input", {
  label: {
    text: "Continuation link",
    heading_size: "m",
  },
  name: "#{format_name}[continuation_link]",
  value: @document.continuation_link,
  type: "url",
} %>

<%= render "govuk_publishing_components/components/input", {
  label: {
    text: "Will continue",
    heading_size: "m",
  },
  name: "#{format_name}[will_continue_on]",
  value: @document.will_continue_on,
  type: "url",
} %>

<%= page_facets = [
    :types_of_support,
    :business_sizes,
    :industries,
    :regions,
    :business_stages,
] %>

<% page_facets.each do |field_config| %>
  <%= render FacetInputComponent.new(@document, schema, schema.get_facet(field_config)) %>
<% end %>
