<% format_name = f.object.class.finder_schema.filter["format"].to_sym %>
<% schema = f.object.class.finder_schema %>
<%= render layout: "shared/specialist_document_form", locals: { f: f } do %>
<% end %>

<%= render "govuk_publishing_components/components/select", {
  id: "#{@document_type}_primary_publishing_organisation",
  name: "#{@document_type}[primary_publishing_organisation]",
  label: "Select a primary publishing organisation",
  heading_size: "m",
  full_width: true,
  error_message: errors_for_input(@document.errors, :primary_publishing_organisation),
  options: organisations_select_options,
} %>

<%= render "govuk_publishing_components/components/select", {
  id: "#{@document_type}_organisations",
  name: "#{@document_type}[organisations]",
  label: "Select organisations",
  heading_size: "m",
  full_width: true,
  error_message: errors_for_input(@document.errors, :organisations),
  options: organisations_select_options,
} %>
