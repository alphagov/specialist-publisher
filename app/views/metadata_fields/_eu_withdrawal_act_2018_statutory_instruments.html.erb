<% format_name = f.object.class.finder_schema.filter["format"].to_sym %>
<% schema = f.object.class.finder_schema %>

<% facet_key = :sift_end_date %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<% facet_key = :laid_date %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<% facet_key = :sifting_status %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>



<% # TODO: this bit of logic prevents us moving to the shared view %>

<% withdrawn_date_display = f.object.withdrawn_sifting_status? ? "block" : "none" %>
<div class="withdrawn-date-wrapper" style="display:<%= withdrawn_date_display %>">
  <%= render "shared/legacy/date_fields_legacy", f: f, field: :withdrawn_date, format: :statutory_instrument %>
</div>

<% facet_key = :subject %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<%= render "govuk_publishing_components/components/select", {
  id: "#{@document_type}_primary_publishing_organisation",
  name: "#{@document_type}[primary_publishing_organisation]",
  label: "Select a primary publishing organisation",
  heading_size: "m",
  full_width: true,
  error_message: errors_for_input(@document.errors, :primary_publishing_organisation),
  options: organisations_select_options,
} %>

<%= render "govuk_publishing_components/components/select", {
  id: "#{@document_type}_organisations",
  name: "#{@document_type}[organisations]",
  label: "Select organisations",
  heading_size: "m",
  full_width: true,
  error_message: errors_for_input(@document.errors, :organisations),
  options: organisations_select_options,
} %>

<% # TODO: this bit of JS prevents us moving to the shared view %>
<% content_for :document_ready do %>
  var $withdrawnDateEl = $(".withdrawn-date-wrapper");
  var $withdrawnDateFields = $("input[id^='statutory_instrument_withdrawn_date']");
  var $siftEndDateFields = $("input[id^='statutory_instrument_sift_end_date']");
  $("#statutory_instrument_sifting_status").change(function(e) {
    if (e.target.value === "withdrawn") {
      $withdrawnDateEl.show();
      $siftEndDateFields.val("");
    } else {
      $withdrawnDateEl.hide();
      $withdrawnDateFields.val("");
    }
  });
<% end %>
