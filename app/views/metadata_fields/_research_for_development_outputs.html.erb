<% format_name = f.object.class.finder_schema.filter["format"].to_sym %>
<% schema = f.object.class.finder_schema %>

<% facet_key = :research_document_type %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<% # TODO: Investigate what options we have for text input with selection %>
<%= render "govuk_publishing_components/components/input", {
  label: {
    text: "Authors",
    heading_size: "m",
  },
  name: "#{format_name}[authors]",
  id: "#{format_name}_authors",
  value: @document.authors,
} %>

<% facet_key = :country %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<% facet_key = :theme %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<% # TODO: Investigate if this date format is correct %>
<% facet_key = :first_published_at %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(facet_key)) %>

<%= render "govuk_publishing_components/components/select", {
  id: "#{@document_type}_review_status",
  name: "#{@document_type}[review_status]",
  label: "Review status",
  heading_size: "m",
  full_width: true,
  error_message: errors_for_input(@document.errors, :review_status),
  options: review_status_options,
} %>
