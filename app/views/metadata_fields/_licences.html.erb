<% schema = f.object.class.finder_schema %>

<%= render FacetInputComponent.new(@document, schema, schema.get_facet(:licence_transaction_industry)) %>
<%= render FacetInputComponent.new(@document, schema, schema.get_facet(:licence_transaction_location)) %>

<% document_type = f.object.class.finder_schema.filter["format"].to_sym %>
<%= render FacetInputComponent::OrganisationSingleSelectComponent.new(@document, document_type, :primary_publishing_organisation, "Primary organisation", selected_organisation_or_current(@document.primary_publishing_organisation)) %>
<!-- TODO: to be migrated over -->
<%= render FacetInputComponent::MultiSelectComponent.new(@document, document_type, :organisations, "Other associated organisations", organisation_select_options(with: :blank)) %>

<div class="additional-field-context-section">
  <h2>How users apply</h2>

<!-- TODO: to be stylised-->
  <% if field_has_errors(@document, :base) %>
    <div class="elements-error">
      <p class="elements-error-message"><%= t("activemodel.errors.models.licence_transaction.attributes.base.link_and_identifier_exists") %></p>
    </div>
  <% else %>
    <p>Enter either the website where users can apply for the licence, or the licence identifier.</p>
  <% end %>
</div>

<%= render FacetInputComponent::InputComponent.new(@document, document_type, :licence_transaction_will_continue_on, "Name of website where users apply") %>
<%= render FacetInputComponent::InputComponent.new(@document, document_type, :licence_transaction_continuation_link, "Link to where users apply", "url") %>
<%= render FacetInputComponent::InputComponent.new(@document, document_type, :licence_transaction_licence_identifier, "Licence identifier") %>
