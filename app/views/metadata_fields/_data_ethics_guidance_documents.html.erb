<%= render layout: "shared/form_group", locals: { f: f, field: :key_reference } do %>
  <%= f.select :key_reference, facet_options(f, :key_reference), {}, { class: 'form-control' } %>
<% end %>
<%= render layout: "shared/form_group", locals: { f: f, field: :ethical_theme } do %>
  <%= f.select :ethical_theme,
      facet_options(f, :ethical_theme),
      {},
      {
        class: 'select2 form-control',
        multiple: true,
      }
  %>
<% end %>
